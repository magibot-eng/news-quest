{
  "rewrites": [
    { "source": "/api/news", "destination": "/api/news" },
    { "source": "/api/categories", "destination": "/api/categories" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
